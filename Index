<script>
// ===== NAVIGATION =====
function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  APP.currentPage = page;

  // highlights
  document.querySelectorAll('.nav-link').forEach(l => {
    if (l.textContent.toLowerCase().includes(page)) l.classList.add('active');
  });

  if (page === 'shop') renderShopGrid();
  if (page === 'orders') renderOrders();
  if (page === 'admin') {
    if (!APP.isAdmin) { showToast('Admin access required', true); navigate('home'); return; }
    renderAdminDashboard();
  }
  if (page === 'profile') renderProfile();
  if (page === 'checkout') renderCheckout();
}

// ===== PRODUCTS =====
function getJerseyEmoji(cat) {
  const map = { football: '⚽', streetwear: '🧢', retro: '📼', collab: '🤝' };
  return map[cat] || '👕';
}

function getBadgeClass(badge) {
  const m = { SALE:'sale', COLLAB:'collab', HOT:'hot', NEW:'new' };
  return m[badge] || '';
}

function renderProductCard(p, container) {
  const card = document.createElement('div');
  card.className = 'product-card';
  const discount = p.originalPrice ? Math.round((1 - p.price / p.originalPrice) * 100) : null;
  card.innerHTML = `
    <div class="product-img">
      <div class="product-img-placeholder">${getJerseyEmoji(p.category)}</div>
      <span class="product-badge ${getBadgeClass(p.badge)}">${p.badge}</span>
      ${p.stock <= 5 ? `<span style="position:absolute;bottom:12px;right:12px;background:rgba(255,45,120,.2);border:1px solid var(--accent2);color:var(--accent2);font-family:var(--font-mono);font-size:9px;padding:3px 8px;letter-spacing:1px">ONLY ${p.stock} LEFT</span>` : ''}
    </div>
    <div class="product-info">
      <div class="product-team">${p.team}</div>
      <div class="product-name">${p.name}</div>
      <div class="product-price-row">
        <span class="product-price">$${p.price}</span>
        ${p.originalPrice ? `<span class="product-original">$${p.originalPrice}</span><span style="font-family:var(--font-mono);font-size:10px;color:var(--accent2);background:rgba(255,45,120,.1);padding:2px 6px;border-radius:2px">-${discount}%</span>` : ''}
      </div>
      <div class="product-rating">
        <span>★</span> ${p.rating} <span style="color:var(--border)">(${p.reviews})</span>
      </div>
      <div class="product-sizes" id="sizes-${p.id}">
        ${p.sizes.map(s => `<span class="size-chip" onclick="selectSize('${p.id}','${s}',this)">${s}</span>`).join('')}
      </div>
      <button class="add-to-cart" onclick="addToCart('${p.id}')">Add to Bag</button>
    </div>`;
  container.appendChild(card);
}

function renderFeatured() {
  const g = document.getElementById('featuredGrid');
  if (!g) return;
  g.innerHTML = '';
  APP.products.slice(0, 3).forEach(p => renderProductCard(p, g));
}

function renderShopGrid(filter = 'all') {
  const g = document.getElementById('shopGrid');
  if (!g) return;
  g.innerHTML = '';
  const filtered = filter === 'all' ? APP.products : APP.products.filter(p => p.category === filter);
  filtered.forEach(p => renderProductCard(p, g));
}

function filterProducts(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderShopGrid(cat);
}

// ===== SIZE SELECTION =====
const selectedSizes = {};
function selectSize(productId, size, el) {
  document.querySelectorAll(`#sizes-${productId} .size-chip`).forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selectedSizes[productId] = size;
}

// ===== CART =====
function addToCart(productId) {
  const product = APP.products.find(p => p.id === productId);
  if (!product) return;
  const size = selectedSizes[productId] || product.sizes[0];
  const existing = APP.cart.find(i => i.id === productId && i.size === size);
  if (existing) {
    existing.qty++;
  } else {
    APP.cart.push({ ...product, size, qty: 1 });
  }
  saveCart();
  updateCartBadge();
  showToast(`${product.name} added to bag 🛒`);
}

function saveCart() {
  localStorage.setItem('jersify_cart', JSON.stringify(APP.cart));
}

function updateCartBadge() {
  const total = APP.cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cartBadge').textContent = total;
}

function toggleCart() {
  const overlay = document.getElementById('cartOverlay');
  const drawer = document.getElementById('cartDrawer');
  overlay.classList.toggle('open');
  drawer.classList.toggle('open');
  renderCart();
}

function renderCart() {
  const items = document.getElementById('cartItems');
  const footer = document.getElementById('cartFooter');
  if (!APP.cart.length) {
    items.innerHTML = `<div class="cart-empty"><div class="cart-empty-icon">🛒</div><p>YOUR BAG IS EMPTY</p><button class="btn btn-outline" onclick="toggleCart();navigate('shop')" style="margin-top:8px">Shop Now →</button></div>`;
    footer.innerHTML = '';
    return;
  }
  items.innerHTML = APP.cart.map((item, i) => `
    <div class="cart-item">
      <div class="cart-item-img">${getJerseyEmoji(item.category)}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-size">SIZE: ${item.size}</div>
        <div class="cart-item-controls">
          <button class="qty-btn" onclick="changeQty(${i},-1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${i},1)">+</button>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
        <span class="cart-item-price">$${(item.price * item.qty).toFixed(0)}</span>
        <button class="remove-item" onclick="removeItem(${i})">🗑</button>
      </div>
    </div>`).join('');
  const subtotal = APP.cart.reduce((s, i) => s + i.price * i.qty, 0);
  footer.innerHTML = `
    <div class="cart-subtotal">
      <span class="cart-subtotal-label">Subtotal</span>
      <span class="cart-subtotal-val">$${subtotal.toFixed(0)}</span>
    </div>
    <button class="btn btn-primary btn-full" onclick="toggleCart();navigate('checkout')">Checkout →</button>
    <button class="btn btn-outline btn-full" style="margin-top:10px" onclick="toggleCart();navigate('shop')">Continue Shopping</button>`;
}

function changeQty(index, delta) {
  APP.cart[index].qty += delta;
  if (APP.cart[index].qty <= 0) APP.cart.splice(index, 1);
  saveCart(); updateCartBadge(); renderCart();
}

function removeItem(index) {
  APP.cart.splice(index, 1);
  saveCart(); updateCartBadge(); renderCart();
}

// ===== CHECKOUT =====
function renderCheckout() {
  const items = document.getElementById('orderSummaryItems');
  if (!items) return;
  items.innerHTML = APP.cart.map(i => `
    <div class="order-summary-item">
      <span>${i.name} × ${i.qty} (${i.size})</span>
      <span>$${(i.price * i.qty).toFixed(0)}</span>
    </div>`).join('');
  const subtotal = APP.cart.reduce((s, i) => s + i.price * i.qty, 0);
  const tax = subtotal * 0.08;
  document.getElementById('sum_sub').textContent = '$' + subtotal.toFixed(0);
  document.getElementById('sum_tax').textContent = '$' + tax.toFixed(0);
  document.getElementById('sum_total').textContent = '$' + (subtotal + tax).toFixed(0);
  document.getElementById('co_total').textContent = '$' + (subtotal + tax).toFixed(0);
  if (APP.user) {
    document.getElementById('co_email').value = APP.user.email || '';
    document.getElementById('co_name').value = APP.user.displayName || '';
  }
}

function formatCard(el) {
  let v = el.value.replace(/\D/g,'').substring(0,16);
  el.value = v.replace(/(.{4})/g,'$1 ').trim();
}
function formatExpiry(el) {
  let v = el.value.replace(/\D/g,'');
  if (v.length >= 2) v = v.substring(0,2) + ' / ' + v.substring(2,4);
  el.value = v;
}

async function placeOrder() {
  if (!APP.cart.length) { showToast('Your cart is empty!', true); return; }
  const name = document.getElementById('co_name').value;
  const addr = document.getElementById('co_addr').value;
  if (!name || !addr) { showToast('Please fill in shipping details', true); return; }

  const subtotal = APP.cart.reduce((s, i) => s + i.price * i.qty, 0);
  const tax = subtotal * 0.08;
  const total = (subtotal + tax).toFixed(2);
  const orderId = 'JRS-' + Date.now();

  const orderData = {
    orderId,
    userId: APP.user?.uid || 'guest',
    customerName: name,
    email: document.getElementById('co_email').value,
    address: addr + ', ' + document.getElementById('co_city').value,
    items: APP.cart,
    subtotal, tax: parseFloat(tax.toFixed(2)), total: parseFloat(total),
    status: 'processing',
    createdAt: new Date().toISOString()
  };

  // Save to Firestore if available
  try {
    await APP.addDoc(APP.collection(APP.db, 'orders'), orderData);
  } catch(e) {
    // Demo mode — just store locally
    APP.orders.unshift(orderData);
  }

  APP.cart = [];
  saveCart(); updateCartBadge();
  showToast(`Order ${orderId} placed! 🎉`);
  navigate('orders');
}

