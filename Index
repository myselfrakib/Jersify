function showTrackModal(orderId, status) {
  const steps = ['confirmed','processing','shipped','out_for_delivery','delivered'];
  const statusMap = { processing:1, shipped:2, out_for_delivery:3, delivered:4 };
  const current = statusMap[status] ?? 1;
  const icons = ['✅','📦','🚚','🏃','🏠'];
  const labels = ['Confirmed','Processing','Shipped','Out for Delivery','Delivered'];

  const result = document.getElementById('trackResult');
  result.innerHTML = `
    <div class="track-box" style="margin-bottom:40px">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;flex-wrap:wrap;gap:12px">
        <div>
          <div class="order-id" style="font-size:16px">${orderId}</div>
          <div style="font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:4px">Estimated delivery: 3-5 business days</div>
        </div>
        <span class="order-status status-${status}">${status}</span>
      </div>
      <div class="track-steps">
        ${icons.map((icon, i) => `
          <div class="track-step ${i < current ? 'done' : i === current ? 'active' : ''}">
            <div class="track-step-dot">${icon}</div>
            <div class="track-step-label">${labels[i]}</div>
          </div>`).join('')}
      </div>
    </div>`;
}

function trackOrder() {
  const id = document.getElementById('trackInput').value.trim();
  if (!id) return;
  showTrackModal(id, 'shipped');
}

// ===== AUTH =====
function switchAuthTab(tab) {
  document.getElementById('loginForm').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('signupForm').style.display = tab === 'signup' ? 'block' : 'none';
  document.getElementById('loginTab').classList.toggle('active', tab === 'login');
  document.getElementById('signupTab').classList.toggle('active', tab === 'signup');
  document.getElementById('authError').style.display = 'none';
}

function showAuthError(msg) {
  const el = document.getElementById('authError');
  el.textContent = msg; el.style.display = 'block';
}

async function doLogin() {
  const email = document.getElementById('loginEmail').value;
  const pass = document.getElementById('loginPassword').value;
  try {
    await APP.signInWithEmailAndPassword(APP.auth, email, pass);
    closeModal('auth');
    showToast('Welcome back! 🔥');
  } catch(e) {
    showAuthError(e.message.replace('Firebase: ', '').replace(' (auth/wrong-password)','').replace('(auth/user-not-found)','No account with that email.'));
  }
}

async function doSignup() {
  const email = document.getElementById('signupEmail').value;
  const pass = document.getElementById('signupPassword').value;
  try {
    await APP.createUserWithEmailAndPassword(APP.auth, email, pass);
    closeModal('auth');
    showToast('Account created! Welcome to JERSIFY 🎉');
  } catch(e) {
    showAuthError(e.message.replace('Firebase: ', ''));
  }
}

async function doGoogleLogin() {
  try {
    await APP.signInWithPopup(APP.auth, APP.googleProvider);
    closeModal('auth');
    showToast('Logged in with Google! 🚀');
  } catch(e) {
    showAuthError('Google sign-in failed. Check Firebase config.');
  }
}

async function doSignOut() {
  await APP.signOut(APP.auth);
  navigate('home');
  showToast('Signed out. See you soon! 👋');
}

window.renderAuthState = function() {
  const user = APP.user;
  const area = document.getElementById('navAuthArea');
  const adminBtns = [document.getElementById('adminNavBtn'), document.getElementById('adminMobileBtn')];
  if (user) {
    const initials = (user.displayName || user.email || '?')[0].toUpperCase();
    area.innerHTML = `<button class="nav-btn" onclick="navigate('profile')" style="border-color:var(--accent);color:var(--accent)">${initials} — Account</button>`;
    adminBtns.forEach(b => { if (b && APP.isAdmin) b.style.display = 'block'; });
  } else {
    area.innerHTML = `<button class="nav-btn primary" onclick="openModal('auth')">Login</button>`;
    adminBtns.forEach(b => { if (b) b.style.display = 'none'; });
  }
};

// ===== MODALS =====
function openModal(name) {
  document.getElementById(name === 'auth' ? 'authModal' : 'addProductModal').classList.add('open');
}
function closeModal(name) {
  document.getElementById(name === 'auth' ? 'authModal' : 'addProductModal').classList.remove('open');
}
document.getElementById('authModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal('auth');
});
document.getElementById('addProductModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal('addProduct');
});

