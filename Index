function updateOrderStatus(orderId, status) {
  const order = APP.orders.find(o => o.orderId === orderId);
  if (order) order.status = status;
  showToast(`Order ${orderId} → ${status} ✅`);
}

function openAddProductModal() { openModal('addProduct'); }
function addProduct() {
  const p = {
    id: 'p' + Date.now(),
    name: document.getElementById('ap_name').value || 'New Jersey',
    team: document.getElementById('ap_team').value || 'Team',
    price: parseInt(document.getElementById('ap_price').value) || 79,
    stock: parseInt(document.getElementById('ap_stock').value) || 10,
    category: document.getElementById('ap_category').value,
    badge: document.getElementById('ap_badge').value,
    originalPrice: null, color: '#0ff', sizes: ['S','M','L','XL'],
    rating: 4.5, reviews: 0
  };
  APP.products.push(p);
  document.getElementById('adminProductCount').textContent = APP.products.length;
  closeModal('addProduct');
  showToast(`${p.name} added! 👕`);
  renderAdminProducts();
}

function deleteProduct(index) {
  APP.products.splice(index, 1);
  renderAdminProducts();
  showToast('Product removed', true);
}

function editProduct(index) { showToast('Edit product — connect to Firestore 🔧'); }

// ===== PROFILE =====
function renderProfile() {
  const user = APP.user;
  if (!user) { navigate('home'); openModal('auth'); return; }
  const initials = (user.displayName || user.email || '?')[0].toUpperCase();
  document.getElementById('profileAvatar').textContent = initials;
  document.getElementById('profileName').textContent = user.displayName || 'JERSIFY USER';
  document.getElementById('profileEmail').textContent = user.email || '';
  document.getElementById('editName').value = user.displayName || '';
  document.getElementById('editEmail').value = user.email || '';
}

// ===== TOAST =====
function showToast(msg, isError = false) {
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = `toast${isError ? ' error' : ''}`;
  toast.innerHTML = `<span>${isError ? '⚠️' : '✅'}</span>${msg}`;
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.animation = 'toastOut .3s ease both';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

